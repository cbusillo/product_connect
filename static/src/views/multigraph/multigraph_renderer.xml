<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web.MultigraphRenderer">
        <div class="o_graph_renderer o_multigraph_renderer">
            <t t-if="props and props.model and props.model.hasData and props.model.hasData()">
                <div class="o_graph_canvas_container">
                    <canvas t-ref="canvas"/>
                </div>
            </t>
            <t t-else="">
                <div class="o_graph_no_data">
                    <span>No data to display</span>
                </div>
            </t>
        </div>
    </t>
</templates>