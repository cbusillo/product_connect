<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web.MultigraphRenderer">
        <div class="o_graph_renderer o_multigraph_renderer">
            <t t-if="!model.data or !model.data.datasets or model.data.datasets.length === 0">
                <div class="o_graph_no_data">
                    <span>No data to display</span>
                </div>
            </t>
            <t t-else="">
                <div class="o_graph_canvas_container">
                    <canvas t-ref="canvas"/>
                </div>
            </t>
        </div>
    </t>
</templates>