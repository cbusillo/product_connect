[run]
branch = True
source = .
omit =
    */services/shopify/gql/*
    */graphql/schema/*
    */tests/*
    */static/*
    */migrations/*
    */venv/*
    */env/*
    */__pycache__/*

[report]
skip_covered = True
exclude_lines =
    if TYPE_CHECKING:
    pragma: no cover
    pass  # unreachable
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError

[html]
directory = test-results/htmlcov